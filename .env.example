# SimpleRemote session security
SR_SESSION_SECRET=long_random_string

# Hue proxy (recommended: v2)
SR_HUE_ENABLED=true
SR_HUE_API_VERSION=auto
SR_HUE_BRIDGE_IP=user_hue_bridge_ip
SR_HUE_APPLICATION_KEY=hue_app_key
SR_HUE_USER_ID=
SR_HUE_INSECURE_SKIP_VERIFY=true
SR_HUE_POLL_INTERVAL_MS=15000
SR_HUE_ENABLE_EVENTSTREAM=true
